{
  "name": "ajan",
  "version": "0.1.0",
  "description": "AI-safe MCP server for schema-aware, read-only SQL access.",
  "bin": {
    "ajan": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
