  "author": "Bora Kilicoglu",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.6",
    "husky": "^9.1.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
